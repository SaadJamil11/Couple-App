# Dependencies and build output
node_modules/
.expo/
dist/
web-build/
yarn-error.log
npm-debug.*
*.log

# Native build folders generated by `expo prebuild`
ios/
android/

# Signing material — never commit
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision
credentials.json
.credentials

# Environment and secrets — keep these on YOUR machine only.
# Use .env.example as the template that gets committed instead.
.env
.env.local
.env.*.local

# OS junk
.DS_Store
*.orig.*
